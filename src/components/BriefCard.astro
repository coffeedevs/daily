---
interface Props {
  slug: string;
  title: string;
  date: Date;
  extract: string;
  tags?: string[];
}

const { slug, title, date, extract, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group py-6">
  <a href={`/briefs/${slug}`} class="block no-underline">
    <time class="text-sm text-espresso-muted font-mono tracking-wide uppercase">
      {formattedDate}
    </time>
    <h2 class="font-serif text-xl md:text-2xl font-semibold text-espresso mt-1 mb-2 group-hover:text-caramel-dark transition-colors">
      {title}
    </h2>
    <p class="text-espresso-light leading-relaxed mb-3">
      {extract}
    </p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.map((tag) => (
          <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-cream-dark text-espresso-muted">
            {tag}
          </span>
        ))}
      </div>
    )}
    <span class="text-sm text-caramel-dark font-medium group-hover:text-caramel transition-colors">
      Read more →
    </span>
  </a>
</article>
