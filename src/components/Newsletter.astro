---
import { t } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section class="bg-white rounded-xl border border-warm-border p-6 md:p-8 shadow-sm">
  <h3 class="font-serif text-lg font-semibold text-espresso mb-1">
    {t(lang, 'newsletter.title')}
  </h3>
  <p class="text-espresso-light text-sm mb-4">
    {t(lang, 'newsletter.desc')}
  </p>
  <form
    action="#"
    method="POST"
    class="flex flex-col sm:flex-row gap-3"
  >
    <input
      type="email"
      name="email"
      placeholder={t(lang, 'newsletter.placeholder')}
      required
      class="flex-1 px-4 py-2.5 rounded-lg border border-warm-border bg-cream text-espresso placeholder:text-espresso-muted focus:outline-none focus:border-caramel focus:ring-1 focus:ring-caramel text-sm"
    />
    <button
      type="submit"
      class="px-6 py-2.5 rounded-lg bg-caramel text-white font-medium text-sm hover:bg-caramel-dark transition-colors cursor-pointer whitespace-nowrap"
    >
      {t(lang, 'newsletter.button')}
    </button>
  </form>
  <p class="text-xs text-espresso-muted mt-3">
    {t(lang, 'newsletter.disclaimer')}
  </p>
</section>
