---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Newsletter from '../../components/Newsletter.astro';
import Navigation from '../../components/Navigation.astro';

export async function getStaticPaths() {
  const allBriefs = await getCollection('briefs');
  const sorted = allBriefs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((brief, index) => ({
    params: { slug: brief.id },
    props: {
      brief,
      prev: index < sorted.length - 1
        ? { slug: sorted[index + 1].id, title: sorted[index + 1].data.title }
        : null,
      next: index > 0
        ? { slug: sorted[index - 1].id, title: sorted[index - 1].data.title }
        : null,
    },
  }));
}

const { brief, prev, next } = Astro.props;
const { Content } = await render(brief);

const formattedDate = brief.data.date.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={brief.data.title} description={brief.data.extract}>
  <Header compact />

  <main class="flex-1 max-w-2xl mx-auto w-full px-6 py-10">
    <article>
      <header class="mb-8">
        <a
          href="/"
          class="text-sm text-espresso-muted hover:text-caramel-dark transition-colors no-underline"
        >
          ← Back to all briefs
        </a>
        <time class="block text-sm text-espresso-muted font-mono tracking-wide uppercase mt-6">
          {formattedDate}
        </time>
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-espresso mt-2 tracking-tight leading-tight">
          {brief.data.title}
        </h1>
        {brief.data.tags && brief.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {brief.data.tags.map((tag: string) => (
              <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-cream-dark text-espresso-muted">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    <Navigation prev={prev} next={next} />

    <div class="mt-10">
      <Newsletter />
    </div>
  </main>

  <Footer />
</BaseLayout>
