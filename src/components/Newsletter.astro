---
import { t } from '../i18n/ui';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
---

<section class="bg-white rounded-xl border border-warm-border p-6 md:p-8 shadow-sm">
  <h3 class="font-serif text-lg font-semibold text-espresso mb-1">
    {t(lang, 'newsletter.title')}
  </h3>
  <p class="text-espresso-light text-sm mb-4">
    {t(lang, 'newsletter.desc')}
  </p>
  <form
    id="newsletter-form"
    class="flex flex-col sm:flex-row gap-3"
  >
    <input
      type="email"
      name="email"
      placeholder={t(lang, 'newsletter.placeholder')}
      required
      class="flex-1 px-4 py-2.5 rounded-lg border border-warm-border bg-cream text-espresso placeholder:text-espresso-muted focus:outline-none focus:border-caramel focus:ring-1 focus:ring-caramel text-sm"
    />
    <button
      type="submit"
      class="px-6 py-2.5 rounded-lg bg-caramel text-white font-medium text-sm hover:bg-caramel-dark transition-colors cursor-pointer whitespace-nowrap"
    >
      {t(lang, 'newsletter.button')}
    </button>
  </form>
  <p id="newsletter-msg" class="text-xs mt-3 hidden"
    data-success={t(lang, 'newsletter.success')}
    data-existing={t(lang, 'newsletter.existing')}
    data-error={t(lang, 'newsletter.error')}
  ></p>
  <p id="newsletter-disclaimer" class="text-xs text-espresso-muted mt-3">
    {t(lang, 'newsletter.disclaimer')}
  </p>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('newsletter-msg')!;
  const disclaimer = document.getElementById('newsletter-disclaimer')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button')!;
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = '...';

    try {
      const email = new FormData(form).get('email');
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();

      if (data.ok) {
        msg.textContent = data.existing
          ? msg.dataset.existing!
          : msg.dataset.success!;
        msg.className = 'text-xs mt-3 text-green-700';
        disclaimer.classList.add('hidden');
        form.classList.add('hidden');
      } else {
        msg.textContent = msg.dataset.error!;
        msg.className = 'text-xs mt-3 text-red-600';
        btn.disabled = false;
        btn.textContent = originalText;
      }
    } catch {
      msg.textContent = msg.dataset.error!;
      msg.className = 'text-xs mt-3 text-red-600';
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });
</script>
